# Optional path override for the global config file.
# Default: ~/.recode/config.json
RECODE_CONFIG_PATH=~/.recode/config.json

# Optional active provider ID from ~/.recode/config.json.
# This lets you switch the active configured provider without editing the file.
RECODE_ACTIVE_PROVIDER=

# Optional provider kind override:
# openai | openai-chat | anthropic | gemini | groq | aihubmix | deepseek | z-ai | z-ai-coding | huggingface
# openai: OpenAI Responses API
# openai-chat: OpenAI Chat Completions API
# anthropic: Anthropic Messages API
# gemini: Google AI Studio / Gemini OpenAI-compatible API
# groq: Groq OpenAI-compatible API
# aihubmix: AIHubMix OpenAI-compatible API gateway
# deepseek: DeepSeek OpenAI-compatible API
# z-ai: Z.AI / GLM general endpoint
# z-ai-coding: Z.AI / GLM Coding Plan endpoint
# huggingface: Hugging Face Inference Providers router
RECODE_PROVIDER=

# Optional API key override. Leave empty when the configured provider already stores it
# or when your local OpenAI-compatible endpoint does not require auth.
RECODE_API_KEY=

# Optional base URL override.
# OpenAI:    https://api.openai.com/v1
# Anthropic: https://api.anthropic.com/v1
# Gemini:    https://generativelanguage.googleapis.com/v1beta/openai
# Groq:      https://api.groq.com/openai/v1
# AIHubMix:  https://aihubmix.com/v1
# DeepSeek:  https://api.deepseek.com
# Z.AI:      https://api.z.ai/api/paas/v4
# Z.AI Coding Plan: https://api.z.ai/api/coding/paas/v4
# Hugging Face: https://router.huggingface.co/v1
# Ollama:    http://127.0.0.1:11434/v1
# OpenRouter: https://openrouter.ai/api/v1
RECODE_BASE_URL=

# Optional model ID override.
RECODE_MODEL=
