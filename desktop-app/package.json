{
  "name": "recode-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run scripts/dev.ts",
    "electrobun:dev": "electrobun dev",
    "web:build": "bun run scripts/build-web.ts",
    "build": "bun run web:build && electrobun build",
    "build:canary": "bun run web:build && electrobun build --env=canary",
    "build:stable": "bun run web:build && electrobun build --env=stable",
    "check": "tsc --noEmit",
    "smoke:spawn": "bun run scripts/smoke-child-spawn.ts",
    "smoke:acp": "bun run scripts/smoke-acp-sessions.ts"
  },
  "dependencies": {
    "electrobun": "^1.18.1"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/three": "^0.184.1",
    "typescript": "^6.0.3"
  }
}
